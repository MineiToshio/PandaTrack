# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Postgres connection string (e.g. Neon, local). Required for Prisma and app data.
DATABASE_URL=

# -----------------------------------------------------------------------------
# Auth (Better Auth)
# -----------------------------------------------------------------------------
# Secret for signing sessions and tokens. Generate with: npx auth@latest secret
BETTER_AUTH_SECRET=
# Google OAuth: create credentials in Google Cloud Console for sign-in with Google.
BETTER_AUTH_GOOGLE_CLIENT_ID=
BETTER_AUTH_GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
# API key from Resend dashboard. Used for transactional emails (verification, password reset).
RESEND_API_KEY=
# Sender address shown in outgoing emails.
RESEND_FROM_EMAIL=hello@pandatrack.app

# -----------------------------------------------------------------------------
# Waitlist / marketing (ConvertKit – Kit)
# -----------------------------------------------------------------------------
# API key from ConvertKit. Used to add waitlist signups as subscribers.
KIT_API_KEY=
# ConvertKit tag IDs per locale and segment (numeric IDs from ConvertKit).
KIT_TAG_ID_ES=
KIT_TAG_ID_EN=
KIT_TAG_ID_APP_USER=
KIT_TAG_ID_WAITLIST=

# -----------------------------------------------------------------------------
# Waitlist (Google Apps Script)
# -----------------------------------------------------------------------------
# Web app URL of the Google Apps Script that receives waitlist submissions (if used).
GOOGLE_APPS_SCRIPT_WAITLIST_WEB_APP_URL=

# -----------------------------------------------------------------------------
# Monitoring (Sentry)
# -----------------------------------------------------------------------------
# Auth token for Sentry CLI (source maps, releases). From Sentry project settings.
SENTRY_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Analytics (PostHog)
# -----------------------------------------------------------------------------
# Project API key and host from PostHog. Used for product analytics and feature flags.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# -----------------------------------------------------------------------------
# App / site
# -----------------------------------------------------------------------------
# Public base URL of the app (used for links, OG, redirects). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://pandatrack.app

# -----------------------------------------------------------------------------
# E2E tests (Playwright)
# -----------------------------------------------------------------------------
# Optional. Only required to run authenticated app shell E2E tests (burger menu, breadcrumbs).
# Use a real test user; tests perform sign-in and then assert on the app layout.
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
