{
  "name": "pandatrack",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && prisma migrate deploy && next build",
    "validate-build": "prisma generate && next build --webpack",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db-push": "npx prisma db push && npx prisma generate",
    "db-reset": "npx prisma migrate reset --force",
    "db-migrate": "npx prisma migrate dev",
    "db-migrate-deploy": "npx prisma migrate deploy",
    "prettier": "prettier --config .prettierrc.json --write \"**/*.*\"",
    "type-check": "tsc --pretty --noEmit",
    "lint": "eslint",
    "download-og-fonts": "node scripts/download-og-fonts.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sentry/nextjs": "^10.38.0",
    "better-auth": "^1.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-intl": "^4.8.2",
    "pg": "^8.18.0",
    "posthog-js": "^1.347.2",
    "posthog-node": "^5.24.15",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "simple-icons": "^16.8.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@fontsource/open-sans": "^5.2.7",
    "@fontsource/roboto-condensed": "^5.2.8",
    "@fontsource/zilla-slab-highlight": "^5.2.8",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.5",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prisma": "^7.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}