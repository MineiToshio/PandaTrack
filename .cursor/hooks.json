{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/format-after-edit.mjs",
        "timeout": 15
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/allow-shell.mjs",
        "timeout": 5
      }
    ],
    "beforeReadFile": [
      {
        "command": "node .cursor/hooks/block-sensitive-read.mjs",
        "timeout": 5
      }
    ]
  }
}
